# Local environment overrides for cmdock-server development.
#
# Copy this file to .env.local and fill in values for your environment.
# .env.local is gitignored; .env.local.example is committed as the template.
#
# The justfile loads this via `set dotenv-filename := ".env.local"`, and the
# ops scripts under scripts/ read the same variables from the environment.

# Staging environment — used by `just deploy-staging`, `just verify-staging-full`,
# scripts/staging_verify.py, scripts/staging_verify_legacy.sh, scripts/real-sync-load.sh
CMDOCK_STAGING_URL="https://staging.example.com"
CMDOCK_STAGING_SSH="staging.example.com"
# Also honoured by scripts/ as STAGING_URL / STAGING_SSH
STAGING_URL="$CMDOCK_STAGING_URL"
STAGING_SSH="$CMDOCK_STAGING_SSH"

# Dogfood / production-like environment — used by `just deploy-dogfood` etc.
CMDOCK_DOGFOOD_URL="https://dogfood.example.com"
CMDOCK_DOGFOOD_SSH="dogfood.example.com"

# Optional: internal CA bundle URL used by scripts/remote-tw-smoke.sh to fetch
# trust roots before running Taskwarrior sync tests. Leave unset if your
# deployment uses a public CA.
CMDOCK_CA_ROOTS_URL=""

# Optional: override the Dockerfile used by scripts/deploy.sh when building
# images for internal hosts that need private CA material. Default is the
# public Dockerfile.
# CMDOCK_DOCKERFILE="Dockerfile"

# Optional: admin HTTP token for staging verify flows
# STAGING_ADMIN_TOKEN=""
